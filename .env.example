PORT=3000

LOG_LEVEL=info

LOG_DIR=./logs

TMP_DIR=./tmp

RTP_TARGET=239.10.10.10
RTP_PORT=5004
RTP_TTL=16

FFMPEG_CODEC=pcm_alaw
SAMPLE_RATE=8000

PIPER_BIN=/opt/piper/piper
PIPER_MODEL=/opt/piper/models/de_DE-eva_k-x_low.onnx
PIPER_THREADS=2

ENABLE_GONG=true
ENABLE_FANFARE=true

AUDIO_VOLUME=1.0
