# =============================================================================
# TTS-ALARMSERVER – Konfiguration
# Kopiere diese Datei nach .env und passe die Werte an.
# WICHTIG: .env niemals in Git einchecken!
# =============================================================================

# --- Server -------------------------------------------------------------------
# Betriebsumgebung: production | development
NODE_ENV=production
# HTTP-Port des Servers
PORT=3000
# Bind-Adresse (0.0.0.0 = alle Interfaces)
HOST=0.0.0.0

# --- Sicherheit ---------------------------------------------------------------
# API-Schlüssel für geschützte Endpunkte (POST /announce, POST /voice).
# Leer lassen = kein Schutz (nur für lokale Entwicklung).
API_KEY=

# --- CORS ---------------------------------------------------------------------
# Einzelner erlaubter Origin:
#   CORS_ORIGIN=https://dashboard.example.com
# Mehrere Origins (kommasepariert):
#   CORS_ORIGINS=https://dashboard.example.com,https://app.example.com
# Leer = in development "*", in production kein CORS
CORS_ORIGIN=
CORS_ORIGINS=

# --- Rate Limiting ------------------------------------------------------------
# Zeitfenster für Rate-Limiting in Millisekunden (Standard: 60000 = 1 Minute)
RATE_LIMIT_WINDOW_MS=60000
# Max. Anfragen pro Zeitfenster und IP für alle Endpunkte
RATE_LIMIT_GLOBAL=200
# Max. Anfragen pro Zeitfenster und IP für POST /announce
RATE_LIMIT_ANNOUNCE=30
# Max. Anfragen pro Zeitfenster und IP für POST /divera
RATE_LIMIT_DIVERA=60

# --- Piper TTS ----------------------------------------------------------------
# Pfad zur Piper-Binary
PIPER_BINARY=/usr/local/bin/piper
# Verzeichnis mit den Voice-Modellen (*.onnx + *.onnx.json)
PIPER_VOICES_DIR=/app/voices
# Standard-Stimme (Dateiname ohne Erweiterung)
PIPER_DEFAULT_VOICE=de_DE-thorsten-high
# Sprechgeschwindigkeit (0.5 – 2.0, Standard: 1.0)
PIPER_SPEED=1.0
# Lautstärke (0 – 100)
PIPER_VOLUME=90
# Timeout für Piper-Synthese in Millisekunden (Standard: 30000 = 30s)
PIPER_TIMEOUT_MS=30000
# Maximale Anzahl Wiederholungsversuche bei Piper-Fehler
PIPER_MAX_RETRIES=2

# --- FFmpeg -------------------------------------------------------------------
# Pfad zur ffmpeg-Binary
FFMPEG_BINARY=/usr/bin/ffmpeg

# --- Audio --------------------------------------------------------------------
# Verzeichnis für Gong-/Fanfare-Dateien
AUDIO_GONG_DIR=/app/gong
# Standard-Gong als Fallback (Dateiname ohne .wav) – wird verwendet wenn kein
# quellenspezifischer Gong (z.B. DIVERA_GONG) gesetzt ist.
# Leer = kein Fallback-Gong
# Beispiel: AUDIO_DEFAULT_GONG=gong
AUDIO_DEFAULT_GONG=
# Millisekunden Pause zwischen Gong und TTS
AUDIO_GONG_DELAY_MS=500
# Millisekunden Pause nach TTS
AUDIO_POST_DELAY_MS=1000

# --- RTP Streaming ------------------------------------------------------------
# Ziel-IP für RTP-Stream (Multicast: 224.x.x.x – 239.x.x.x, Unicast: direkte IP)
RTP_HOST=239.255.0.1
# Ziel-Port für RTP-Stream
RTP_PORT=5004
# Bitrate des Audio-Streams
RTP_BITRATE=128k
# Codec: libopus (empfohlen), pcm_mulaw (G.711), aac
RTP_CODEC=libopus
# Abtastrate in Hz
RTP_SAMPLE_RATE=48000
# Multicast TTL (Time-to-Live, 1 = lokales Subnetz, 32 = site-lokal)
RTP_TTL=32
# Timeout in Sekunden bis Stream als hängend gilt
RTP_TIMEOUT_SEC=30
# Netzwerkinterface für Multicast (leer = Standardinterface)
# Beispiel: RTP_INTERFACE=eth0
RTP_INTERFACE=

# --- Queue --------------------------------------------------------------------
# Maximale Warteschlangengröße (inkl. aktiver Durchsage)
QUEUE_MAX_SIZE=50
# Standard-Priorität wenn nicht angegeben (1 = niedrig, 10 = kritisch)
QUEUE_DEFAULT_PRIORITY=5
# Wartezeit in ms vor erneutem Versuch nach Fehler
QUEUE_RETRY_DELAY_MS=1000

# --- Logging ------------------------------------------------------------------
# Log-Level: error | warn | info | http | debug
LOG_LEVEL=info
# Verzeichnis für Log-Dateien (server.log, error.log, requests.log)
LOG_DIR=/app/logs
# Maximale Log-Dateigröße pro Datei
LOG_MAX_SIZE=20m
# Maximale Anzahl rotierter Log-Dateien (= Aufbewahrungstage bei täglicher Rotation)
LOG_MAX_FILES=14
# Health-Check-Requests aus dem Request-Log ausschließen (true | false)
LOG_SKIP_HEALTH=true

# --- Dashboard / WebSocket ----------------------------------------------------
# WebSocket Ping-Interval in Millisekunden
WS_PING_INTERVAL_MS=30000
# Maximale Einträge in der Alarmhistorie (in-memory)
HISTORY_MAX_ENTRIES=100

# --- Divera 24/7 Integration --------------------------------------------------
# Basis-URL der Divera-API
DIVERA_BASE_URL=https://www.divera247.com/api/v2
# Divera Access-Token (optional, für aktive API-Abfragen)
DIVERA_ACCESS_TOKEN=
# Vorab-Gong für Divera-Alarme (Dateiname ohne .wav, Datei muss in AUDIO_GONG_DIR liegen)
# Leer = kein Gong vor Divera-Alarmierungen
# Beispiel: DIVERA_GONG=feuerwehr_gong
DIVERA_GONG=

# --- Prometheus (optional) ----------------------------------------------------
# Prometheus-Metriken aktivieren
METRICS_ENABLED=false
# Pfad für Metriken-Endpunkt
METRICS_PATH=/metrics
