# =============================================================
# TTS Alarmserver – Konfiguration
# Kopiere diese Datei nach .env und passe die Werte an.
# =============================================================

# Server
PORT=3000
HOST=0.0.0.0

# Piper TTS
# Modelle (Geschwindigkeit vs. Qualität):
#   thorsten-low    -> ~2-4s  (empfohlen für schwache Hardware / LXC)
#   thorsten-medium -> ~11-13s (besser für dedizierte Hardware)
#   thorsten-high   -> ~20-25s (höchste Qualität, braucht viel CPU)
PIPER_BINARY=/usr/local/bin/piper
PIPER_MODEL=/opt/piper/models/de_DE-thorsten-low.onnx
PIPER_MAX_CHUNK=500
PIPER_TIMEOUT_MS=30000
# Ausgabe-Samplerate des gewählten Piper-Modells.
# thorsten-low: 16000; thorsten-medium/high üblicherweise: 22050
PIPER_OUTPUT_SAMPLE_RATE=16000

# Piper Sprechgeschwindigkeit (length_scale)
# < 1.0 = schneller sprechen  |  > 1.0 = langsamer sprechen  |  1.0 = normal
# Empfohlener Bereich: 0.8 – 1.5
PIPER_LENGTH_SCALE=1.0

# FFmpeg
FFMPEG_BINARY=ffmpeg
FFMPEG_TIMEOUT_MS=60000

# Gong vor Alarm-Durchsagen
# Pfad zur Gong-WAV-Datei (absolut oder relativ zu public/).
# Leer lassen um den Gong zu deaktivieren.
# Beispiel: ALARM_GONG_FILE=gong.wav   (liegt dann unter public/gong.wav)
# Beispiel: ALARM_GONG_FILE=/opt/audio/gong.wav
ALARM_GONG_FILE=gong.wav

# RTP-Streaming (Multicast oder Unicast)
RTP_HOST=239.10.10.10
#Unicat direkt IP
#RTP_HOST=192.168.178.5
RTP_PORT=5004
RTP_CODEC=pcm_mulaw
RTP_SAMPLE_RATE=8000
RTP_CHANNELS=1

# Temporäre Dateien
TMP_DIR=/tmp/tts-alarm

# Queue
QUEUE_CONCURRENCY=1
QUEUE_MAX_SIZE=20

# History
HISTORY_MAX_ENTRIES=100

# Logging: error | warn | info | debug
LOG_LEVEL=info

# =============================================================
# API-Authentifizierung
# =============================================================
# Optionaler API-Key für geschützte Endpunkte (z. B. POST /api/voices).
# Wird als X-API-Key-Header oder als Bearer-Token übermittelt:
#   X-API-Key: mein-geheimer-schluessel
#   Authorization: Bearer mein-geheimer-schluessel
# Nicht gesetzt = Endpunkt offen (kein Key erforderlich).
#API_KEY=

# =============================================================
# CORS
# =============================================================
# Erlaubter Origin für Cross-Origin-Anfragen.
# Beispiel (einzeln):  CORS_ORIGIN=https://mein-dashboard.example.com
# Beispiel (mehrere):  CORS_ORIGINS=https://app1.example.com,https://app2.example.com
# Nicht gesetzt = '*' (offen) – für Produktion CORS_ORIGIN explizit setzen!
#CORS_ORIGIN=
#CORS_ORIGINS=

# =============================================================
# Rate-Limiting
# =============================================================
# Zeitfenster in Millisekunden für alle Rate-Limiter (Default: 60000 = 1 Minute)
#RATE_LIMIT_WINDOW_MS=60000

# Maximale Anfragen pro IP und Zeitfenster global (Default: 200)
#RATE_LIMIT_GLOBAL=200

# Maximale Anfragen pro IP für POST /announce – TTS-Pipeline (Default: 30)
#RATE_LIMIT_ANNOUNCE=30

# Maximale Anfragen pro IP für POST /api/divera – Webhook-Eingang (Default: 60)
#RATE_LIMIT_DIVERA=60
