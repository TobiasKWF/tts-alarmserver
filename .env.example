# =============================================================
# TTS Alarmserver – Konfiguration
# Kopiere diese Datei nach .env und passe die Werte an.
# =============================================================

# Server
PORT=3000
HOST=0.0.0.0

# Piper TTS
# Modelle (Geschwindigkeit vs. Qualität):
#   thorsten-low    -> ~2-4s  (empfohlen für schwache Hardware / LXC)
#   thorsten-medium -> ~11-13s (besser für dedizierte Hardware)
#   thorsten-high   -> ~20-25s (höchste Qualität, braucht viel CPU)
PIPER_BINARY=/usr/local/bin/piper
PIPER_MODEL=/opt/piper/models/de_DE-thorsten-low.onnx
PIPER_MAX_CHUNK=500
PIPER_TIMEOUT_MS=30000

# Piper Sprechgeschwindigkeit (length_scale)
# < 1.0 = schneller sprechen  |  > 1.0 = langsamer sprechen  |  1.0 = normal
# Empfohlener Bereich: 0.8 – 1.5
PIPER_LENGTH_SCALE=1.0

# FFmpeg
FFMPEG_BINARY=ffmpeg
FFMPEG_TIMEOUT_MS=60000

# RTP-Streaming (Multicast oder Unicast)
RTP_HOST=239.0.0.1
RTP_PORT=5004
RTP_CODEC=pcm_mulaw
RTP_SAMPLE_RATE=8000
RTP_CHANNELS=1

# Temporäre Dateien
TMP_DIR=/tmp/tts-alarm

# Queue
QUEUE_CONCURRENCY=1
QUEUE_MAX_SIZE=20

# History
HISTORY_MAX_ENTRIES=100

# Logging: error | warn | info | debug
LOG_LEVEL=info
